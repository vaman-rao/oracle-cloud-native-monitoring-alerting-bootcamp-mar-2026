{
  "id": null,
  "uid": "clinic-microservices-dashboard",
  "title": "Clinic Microservices - Monitoring Dashboard",
  "tags": ["clinic", "microservices", "spring-boot"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [

    {
      "id": 1,
      "title": "Services Up/Down",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 4 },
      "targets": [
        {
          "expr": "up{job=~\"oracle-.*|prometheus\"}",
          "legendFormat": "{{job}}"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 1, "color": "green" }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ]
        }
      }
    },

    {
      "id": 2,
      "title": "HTTP Request Rate (req/sec) - All Services",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{job=~\"oracle-.*\"}[1m])",
          "legendFormat": "{{application}} - {{uri}} [{{status}}]"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },

    {
      "id": 3,
      "title": "HTTP Request Latency (p99) - All Services",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{job=~\"oracle-.*\"}[1m]))",
          "legendFormat": "{{application}} p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      }
    },

    {
      "id": 4,
      "title": "JVM Heap Memory Used (MB)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\", job=~\"oracle-.*\"} / 1024 / 1024",
          "legendFormat": "{{application}} heap"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decmbytes", "color": { "mode": "palette-classic" } }
      }
    },

    {
      "id": 5,
      "title": "JVM Non-Heap Memory Used (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"nonheap\", job=~\"oracle-.*\"} / 1024 / 1024",
          "legendFormat": "{{application}} nonheap"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "decmbytes", "color": { "mode": "palette-classic" } }
      }
    },

    {
      "id": 6,
      "title": "CPU Usage Per Service",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "process_cpu_usage{job=~\"oracle-.*\"}",
          "legendFormat": "{{application}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "palette-classic" } }
      }
    },

    {
      "id": 7,
      "title": "Active JVM Threads",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=~\"oracle-.*\"}",
          "legendFormat": "{{application}} live"
        },
        {
          "expr": "jvm_threads_daemon_threads{job=~\"oracle-.*\"}",
          "legendFormat": "{{application}} daemon"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      }
    },

    {
      "id": 8,
      "title": "HTTP Error Rate (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_server_requests_seconds_count{status=~\"4..|5..\", job=~\"oracle-.*\"}[1m])",
          "legendFormat": "{{application}} - {{status}} {{uri}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },

    {
      "id": 9,
      "title": "JVM Garbage Collection Pause Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{job=~\"oracle-.*\"}[1m])",
          "legendFormat": "{{application}} - {{action}} {{cause}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      }
    },

    {
      "id": 10,
      "title": "Service Uptime",
      "type": "stat",
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 4 },
      "targets": [
        {
          "expr": "process_uptime_seconds{job=~\"oracle-.*\"}",
          "legendFormat": "{{application}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      }
    }

  ]
}
